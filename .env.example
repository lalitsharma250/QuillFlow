# ─────────────────────────────────────────────────────────
# QuillFlow Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────
QUILL_DEBUG=true
QUILL_LOG_LEVEL=DEBUG
QUILL_API_PORT=8000

# ── LLM Provider ─────────────────────────────────────────
QUILL_LLM_PROVIDER_BASE_URL=https://openrouter.ai/api/v1
QUILL_LLM_API_KEY=sk-or-v1-your-key-here
QUILL_LLM_MODEL_FAST=anthropic/claude-sonnet-4-20250514
QUILL_LLM_MODEL_STRONG=anthropic/claude-opus-4-6

# ── Embeddings ───────────────────────────────────────────
QUILL_EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5
QUILL_EMBEDDING_DIMENSIONS=1024

# ── Qdrant (Local Development) ───────────────────────────
QUILL_QDRANT_HOST=localhost
QUILL_QDRANT_PORT=6333
QUILL_QDRANT_COLLECTION_NAME=quillflow_chunks
QUILL_QDRANT_PREFER_GRPC=true

# ── Qdrant Cloud (Production) ────────────────────────────
# Uncomment and set these for Qdrant Cloud deployment:
# QUILL_QDRANT_URL=https://xxx.us-east-1-0.aws.cloud.qdrant.io
# QUILL_QDRANT_API_KEY=your-qdrant-api-key
# QUILL_QDRANT_PREFER_GRPC=false

# ── Postgres (Local) ─────────────────────────────────────
QUILL_POSTGRES_HOST=localhost
QUILL_POSTGRES_PORT=5432
QUILL_POSTGRES_USER=quillflow
QUILL_POSTGRES_PASSWORD=quillflow_dev
QUILL_POSTGRES_DB=quillflow
QUILL_POSTGRES_SSL_MODE=disable

# ── Postgres Cloud (Neon) ────────────────────────────────
# For Neon, set:
# QUILL_POSTGRES_HOST=ep-xxx.neon.tech
# QUILL_POSTGRES_SSL_MODE=require

# ── Redis (Local) ────────────────────────────────────────
QUILL_REDIS_URL=redis://localhost:6379/0

# ── Redis Cloud (Upstash) ────────────────────────────────
# For Upstash, set:
# QUILL_REDIS_URL=rediss://default:PASSWORD@xxx.upstash.io:6379

# ── JWT ──────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
QUILL_JWT_SECRET_KEY=change-this-to-a-random-secret
QUILL_JWT_ACCESS_TOKEN_HOURS=1
QUILL_JWT_REFRESH_TOKEN_DAYS=7

# ── Retrieval ────────────────────────────────────────────
QUILL_RETRIEVAL_TOP_K=10
QUILL_RERANKER_TOP_K=5
QUILL_CHUNK_SIZE=512
QUILL_CHUNK_OVERLAP=64