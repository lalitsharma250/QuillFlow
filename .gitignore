# ═══════════════════════════════════════════════════════
# QuillFlow .gitignore
# ═══════════════════════════════════════════════════════

# ── Secrets & Environment ─────────────────────────────
# CRITICAL: Never commit these
.env
.env.local
.env.production
.env.staging
*.env
!.env.example

# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
.venv/
venv/
env/
ENV/

# ── Node / Frontend ───────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/
node_modules/

# ── IDE ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── OS ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Docker Volumes (local data) ──────────────────────
postgres_data/
redis_data/
qdrant_data/
docker/postgres_data/
docker/redis_data/
docker/qdrant_data/

# ── Database ──────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Logs ──────────────────────────────────────────────
*.log
logs/

# ── Testing ───────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ── Linting / Type Checking ──────────────────────────
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# ── ML Models (downloaded at runtime) ────────────────
# These are large and downloaded automatically
*.bin
*.pt
*.onnx
*.safetensors
.cache/
huggingface/

# ── Jupyter ───────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Terraform / Infrastructure ────────────────────────
*.tfstate
*.tfstate.*
.terraform/
*.tfvars

# ── Certificates & Keys ──────────────────────────────
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.jks

# ── Misc ──────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.orig


deployment-credentials.txt
*.credentials
*.env
!.env.example