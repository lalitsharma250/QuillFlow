# ─────────────────────────────────────────────────────────
# QuillFlow Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────
QUILL_DEBUG=true
QUILL_LOG_LEVEL=DEBUG
QUILL_API_PORT=8000

# ── LLM Provider (OpenRouter) ───────────────────────────
QUILL_LLM_PROVIDER_BASE_URL=https://openrouter.ai/api/v1
QUILL_LLM_API_KEY=sk-or-v1-your-key-here
QUILL_LLM_MODEL_FAST=anthropic/claude-sonnet-4-20250514
QUILL_LLM_MODEL_STRONG=anthropic/claude-opus-4-6

# ── Embeddings ───────────────────────────────────────────
QUILL_EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5
QUILL_EMBEDDING_DIMENSIONS=1024

# ── Qdrant ───────────────────────────────────────────────
QUILL_QDRANT_HOST=localhost
QUILL_QDRANT_PORT=6333
QUILL_QDRANT_COLLECTION_NAME=quillflow_chunks

# ── Postgres ─────────────────────────────────────────────
QUILL_POSTGRES_HOST=localhost
QUILL_POSTGRES_PORT=5432
QUILL_POSTGRES_USER=quillflow
QUILL_POSTGRES_PASSWORD=quillflow_dev
QUILL_POSTGRES_DB=quillflow

# ── Redis ────────────────────────────────────────────────
QUILL_REDIS_URL=redis://localhost:6379/0
QUILL_CACHE_TTL_SECONDS=86400

# ── Retrieval ────────────────────────────────────────────
QUILL_RETRIEVAL_TOP_K=10
QUILL_RERANKER_TOP_K=5
QUILL_CHUNK_SIZE=512
QUILL_CHUNK_OVERLAP=64